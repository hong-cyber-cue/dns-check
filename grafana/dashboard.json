        {
          "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
          "queryText": "SELECT datetime(check_time, 'unixepoch', '+8 hours') as time, domain, isp, status, reason, isp_resolved_ip FROM results WHERE check_time > strftime('%s', 'now', '-24 hours') AND id IN (SELECT MIN(id) FROM results r2 WHERE r2.domain=results.domain AND r2.isp=results.isp AND r2.status != (SELECT status FROM results r3 WHERE r3.domain=r2.domain AND r3.isp=r2.isp AND r3.check_time < r2.check_time ORDER BY check_time DESC LIMIT 1) GROUP BY r2.domain, r2.isp, r2.status) ORDER BY check_time DESC LIMIT 50",
          "queryType": "table",
          "rawQueryText": "SELECT datetime(check_time, 'unixepoch', '+8 hours') as time, domain, isp, status, reason, isp_resolved_ip FROM results WHERE check_time > strftime('%s', 'now', '-24 hours') ORDER BY check_time DESC LIMIT 50",
          "refId": "A",
          "timeColumns": []
        }
      ],
      "title": "🚨 最近 24 小時狀態變化",
      "type": "table"
