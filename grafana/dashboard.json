      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "description": "目前所有域名 × ISP 的最新狀態",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "center", "displayMode": "color-background", "inspect": false },
          "mappings": [
            { "options": { "ok": { "color": "green", "index": 0, "text": "✓ OK" } }, "type": "value" },
            { "options": { "blocked": { "color": "red", "index": 1, "text": "✗ BLOCKED" } }, "type": "value" },
            { "options": { "unknown": { "color": "dark-gray", "index": 2, "text": "? UNKNOWN" } }, "type": "value" },
            { "options": { "suspect": { "color": "yellow", "index": 3, "text": "! SUSPECT" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
          "queryText": "SELECT domain, MAX(CASE WHEN isp='Viettel' THEN status END) as Viettel, MAX(CASE WHEN isp='Vinaphone' THEN status END) as Vinaphone, MAX(CASE WHEN isp='Mobifone' THEN status END) as Mobifone, MAX(CASE WHEN isp='Globe' THEN status END) as Globe, MAX(CASE WHEN isp='Smart' THEN status END) as Smart, MAX(CASE WHEN isp='DITO' THEN status END) as DITO FROM results r1 WHERE check_time = (SELECT MAX(check_time) FROM results r2 WHERE r2.domain=r1.domain AND r2.isp=r1.isp) GROUP BY domain ORDER BY domain",
          "queryType": "table",
          "rawQueryText": "SELECT domain, MAX(CASE WHEN isp='Viettel' THEN status END) as Viettel, MAX(CASE WHEN isp='Vinaphone' THEN status END) as Vinaphone, MAX(CASE WHEN isp='Mobifone' THEN status END) as Mobifone, MAX(CASE WHEN isp='Globe' THEN status END) as Globe, MAX(CASE WHEN isp='Smart' THEN status END) as Smart, MAX(CASE WHEN isp='DITO' THEN status END) as DITO FROM results r1 WHERE check_time = (SELECT MAX(check_time) FROM results r2 WHERE r2.domain=r1.domain AND r2.isp=r1.isp) GROUP BY domain ORDER BY domain",
          "refId": "A",
          "timeColumns": []
        }
      ],
      "title": "📊 域名 × ISP 狀態矩陣（最新）",
      "type": "table"
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "description": "每個 ISP 當前的封鎖比例",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
          "queryText": "SELECT isp, ROUND(100.0 * SUM(CASE WHEN status='blocked' THEN 1 ELSE 0 END) / COUNT(*), 1) as block_pct FROM (SELECT r1.* FROM results r1 INNER JOIN (SELECT domain, isp, MAX(check_time) as mt FROM results GROUP BY domain, isp) latest ON r1.domain=latest.domain AND r1.isp=latest.isp AND r1.check_time=latest.mt) GROUP BY isp ORDER BY isp",
          "queryType": "table",
          "rawQueryText": "SELECT isp, ROUND(100.0 * SUM(CASE WHEN status='blocked' THEN 1 ELSE 0 END) / COUNT(*), 1) as block_pct FROM (SELECT r1.* FROM results r1 INNER JOIN (SELECT domain, isp, MAX(check_time) as mt FROM results GROUP BY domain, isp) latest ON r1.domain=latest.domain AND r1.isp=latest.isp AND r1.check_time=latest.mt) GROUP BY isp ORDER BY isp",
          "refId": "A",
          "timeColumns": []
        }
      ],
      "title": "📈 各 ISP 封鎖率",
      "type": "stat"
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "description": "整體封鎖率隨時間變化",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
