            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 3,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
          "queryText": "SELECT (check_time / 3600) * 3600 as time, isp, ROUND(100.0 * SUM(CASE WHEN status='blocked' THEN 1 ELSE 0 END) / COUNT(*), 1) as block_pct FROM results WHERE check_time > strftime('%s', 'now', '-7 days') GROUP BY (check_time / 3600), isp ORDER BY time",
          "queryType": "time series",
          "rawQueryText": "SELECT (check_time / 3600) * 3600 as time, isp, ROUND(100.0 * SUM(CASE WHEN status='blocked' THEN 1 ELSE 0 END) / COUNT(*), 1) as block_pct FROM results WHERE check_time > strftime('%s', 'now', '-7 days') GROUP BY (check_time / 3600), isp ORDER BY time",
          "refId": "A",
          "timeColumns": ["time"]
        }
      ],
      "title": "📉 封鎖率趨勢（過去 7 天，每小時）",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
